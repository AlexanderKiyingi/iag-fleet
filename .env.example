# ─── Postgres ────────────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/haula_fleet

# Run pending migrations during API boot so a freshly-provisioned Postgres
# (Railway, Render, fly.io first deploy) ends up with the full schema before
# the HTTP listener starts. Idempotent: schema_migrations tracks which
# versions have run. Set to "false" to manage migrations externally with
# cmd/seed instead.
AUTO_MIGRATE=true

# ─── Platform integration ────────────────────────────────────────────────
# gateway | jwt (IAM via iag-authentication; no local users table)
AUTH_MODE=gateway
# Required when AUTH_MODE=gateway (must match API gateway GATEWAY_INTERNAL_SECRET)
GATEWAY_INTERNAL_SECRET=dev-gateway-secret-min-16-chars
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://127.0.0.1:3001/.well-known/jwks.json
GATEWAY_API_PREFIX=/api/v1/fleet
PUBLIC_API_URL=http://localhost:8080
AUTHENTICATION_URL=http://127.0.0.1:3001
NOTIFICATIONS_URL=http://127.0.0.1:3002
ACCOUNTS_URL=http://127.0.0.1:3005

# ─── HTTP server ─────────────────────────────────────────────────────────
ADDR=:4008
CORS_ORIGIN=http://localhost:3000

# Display name + base URL embedded in emails (verify/reset links).
APP_NAME=HAULA Fleet
APP_URL=http://localhost:3000

# Mark session cookies Secure (HTTPS only). Required for cross-site/prod.
COOKIE_SECURE=false

# Block login for users whose email_verified=false. Staff/superusers always
# bypass to prevent lockout. Set to "false" to disable the gate.
REQUIRE_EMAIL_VERIFIED=true

# ─── SMTP ────────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to use the LogMailer (emails print to stdout —
# useful in dev to see verification/reset links).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=HAULA Fleet <no-reply@localhost>

# ─── Redis (optional response cache) ─────────────────────────────────────
# Set to enable Redis-backed caching for dashboard/analytics/reference JSON.
# If unset or connection fails, the API runs unchanged with in-process [cache.NoOp].
# REDIS_URL=redis://localhost:6379/0
# TTLs are in seconds (defaults shown):
# CACHE_TTL_DASHBOARD_SEC=30
# CACHE_TTL_ANALYTICS_SEC=45
# CACHE_TTL_REFERENCE_SEC=600

# ─── Event bus (optional) ────────────────────────────────────────────────
# EVENT_BUS_ENABLED=true
# KAFKA_BROKERS=127.0.0.1:19092

# ─── Road routing (optional) ────────────────────────────────────────────
# Base URL of an OSRM-compatible server (no /route path). The API proxies
# POST /api/routing/plan to {ROUTING_OSRM_URL}/route/v1/{profile}/...
# Public demo (rate-limited): https://router.project-osrm.org
# Self-hosted: http://127.0.0.1:5000
# ROUTING_OSRM_URL=https://router.project-osrm.org
#
# When unset or unreachable, /api/routing/plan falls back to a great-circle
# polyline (not road-following).

# ─── IoT gateway ─────────────────────────────────────────────────────────
# cmd/iot-gateway listens here for native Teltonika Codec 8/8E TCP devices.
# Default 5027 is the standard Teltonika port.
IOT_ADDR=:5027
