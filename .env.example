# Local development — see config/.env.production.example for production.
# Copy to .env in this directory or export in your shell.

# ─── Postgres ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://svc_iag_fleet:iag_fleet_dev@localhost:5432/iag_platform?sslmode=disable
AUTO_MIGRATE=true

# ─── Platform integration ────────────────────────────────────────────────
AUTH_MODE=gateway
GATEWAY_INTERNAL_SECRET=dev-gateway-secret-min-16-chars
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://127.0.0.1:3001/.well-known/jwks.json
GATEWAY_API_PREFIX=/api/v1/fleet
PUBLIC_API_URL=http://localhost:8080
AUTHENTICATION_URL=http://127.0.0.1:3001
NOTIFICATIONS_URL=http://127.0.0.1:3002
ACCOUNTS_URL=http://127.0.0.1:3005
PLATFORM_CHECK_DEPS=true

# ─── HTTP server ─────────────────────────────────────────────────────────
PORT=4008
# ADDR=:4008
GIN_MODE=debug
LOG_LEVEL=info
LOG_FORMAT=text
CORS_ORIGIN=http://localhost:3000
APP_NAME=IAG Fleet
APP_URL=http://localhost:3000
COOKIE_SECURE=false

# ─── Event bus ───────────────────────────────────────────────────────────
EVENT_BUS_ENABLED=true
KAFKA_BROKERS=127.0.0.1:19092
FLEET_FUEL_CURRENCY=UGX
FLEET_BASE_DIESEL_UGX=5100

# ─── SMTP (optional) ─────────────────────────────────────────────────────
# Leave SMTP_HOST blank to log emails to stdout.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IAG Fleet <no-reply@localhost>

# ─── Redis cache (optional) ──────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_DASHBOARD_SEC=30
# CACHE_TTL_ANALYTICS_SEC=45
# CACHE_TTL_REFERENCE_SEC=600

# ─── Road routing (optional) ────────────────────────────────────────────
# ROUTING_OSRM_URL=https://router.project-osrm.org

# ─── IoT gateway (cmd/iot-gateway) ───────────────────────────────────────
IOT_ADDR=:5027
