# Production — fleet API (behind iag-api-gateway).
# See docs/PRODUCTION_CHECKLIST.md before go-live.
PORT=4008
# ADDR=:4008
ENVIRONMENT=production
GIN_MODE=release
LOG_LEVEL=info
LOG_FORMAT=json

# Operational registry (vehicles, drivers, iot_devices, outbox)
DATABASE_URL=postgres://svc_iag_fleet:PASSWORD@HOST:5432/iag_platform?sslmode=require
# Telemetry read path — dedicated Timescale instance (omit for single-DB dev)
TELEMETRY_DATABASE_URL=postgres://svc_iag_fleet:PASSWORD@telemetry-host:5432/iag_telemetry?sslmode=require
AUTO_MIGRATE=false

JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json
AUDIENCE=iag.fleet
GATEWAY_API_PREFIX=/api/v1/fleet
PUBLIC_API_URL=https://api.example.com
AUTHENTICATION_URL=https://auth.example.com
NOTIFICATIONS_URL=http://notifications:3002
ACCOUNTS_URL=http://accounts:3005

CORS_ORIGIN=https://app.example.com
APP_NAME=IAG Fleet
APP_URL=https://app.example.com
COOKIE_SECURE=true

EVENT_BUS_ENABLED=true
KAFKA_BROKERS=kafka-broker-1:9092,kafka-broker-2:9092
FLEET_FUEL_CURRENCY=UGX
FLEET_BASE_DIESEL_UGX=5100
PLATFORM_CHECK_DEPS=true

# Permission catalogue registration with iag-authentication (required in production)
SERVICE_CLIENT_ID=iag-fleet
SERVICE_CLIENT_SECRET=CHANGE_ME_MIN_16_CHARS
# JWT_ISSUER must reach auth register endpoint (gateway auth prefix in production)
# AUTH_TOKEN_URL defaults to {JWT_ISSUER}/oauth/token

# Optional Redis cache
# REDIS_URL=redis://redis:6379/0

# SMTP for transactional mail (or leave blank to disable outbound)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=IAG Fleet <fleet@example.com>
